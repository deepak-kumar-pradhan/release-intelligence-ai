AZURE_OPENAI_ENDPOINT=https://ri-hackathon-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY="REPLACE_WITH_YOUR_KEY"
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-07-18
LLM_MAX_FINDINGS_PER_SERVICE=1
LLM_CACHE_ENABLED=false
LLM_CACHE_PATH=session/llm_cache.json
POLICY_LLM_ONLY_AMBER=false
LLM_MAX_RESPONSE_TOKENS=140
POLICY_LLM_MAX_RESPONSE_TOKENS=90
APPLICATIONINSIGHTS_CONNECTION_STRING="REPLACE_WITH_YOUR_APP_INSIGHTS_CONNECTION_STRING"
TRACE_TO_CONSOLE=true