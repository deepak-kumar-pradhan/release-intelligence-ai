# -----------------------------
# Model and runtime behavior
# -----------------------------
# Azure OpenAI deployment name used by Foundry agents.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Limit LLM processing volume per service during triage.
LLM_MAX_FINDINGS_PER_SERVICE=1
# Optional local cache for LLM responses.
LLM_CACHE_ENABLED=false
LLM_CACHE_PATH=session/llm_cache.json
# Keep deterministic policy path primary; enable LLM on AMBER logic only when needed.
POLICY_LLM_ONLY_AMBER=false

# -----------------------------
# Azure AI Foundry project and agent identity
# -----------------------------
# Foundry project endpoint from Azure AI Foundry portal.
AZURE_AI_PROJECT_ENDPOINT="https://ri-hackathon-resource.services.ai.azure.com/api/projects/ri-hackathon"
# Service principal credentials for headless/Docker execution.
AZURE_TENANT_ID="REPLACE-WITH-YOUR-TENANT-ID"
AZURE_CLIENT_ID="REPLACE-WITH-YOUR-CLIENT-ID"
AZURE_CLIENT_SECRET="REPLACE-WITH-YOUR-CLIENT-SECRET"
# Foundry agent names and optional pinned versions.
FOUNDRY_POLICY_AGENT_NAME="policy-governance-agent"
FOUNDRY_POLICY_AGENT_VERSION=4
FOUNDRY_EXPERT_AGENT_NAME="expert-security-agent"
FOUNDRY_EXPERT_AGENT_VERSION=3

# -----------------------------
# Observability
# -----------------------------
# Application Insights connection string for distributed traces.
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=REPLACE-WITH-YOUR-INSTRUMENTATION-KEY;IngestionEndpoint=REPLACE-WITH-YOUR-INGESTION-ENDPOINT;LiveEndpoint=REPLACE-WITH-YOUR-LIVE-ENDPOINT;ApplicationId=REPLACE-WITH-YOUR-APPLICATION-ID"
# Also print trace IDs to local console logs.
TRACE_TO_CONSOLE=true

# -----------------------------
# Attestation artifact storage
# -----------------------------
# Blob settings for finalized attestation PDFs.
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=REPLACE-WITH-YOUR-ACCOUNT-NAME;AccountKey=REPLACE-WITH-YOUR-ACCOUNT-KEY;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER=REPLACE-WITH-YOUR-CONTAINER-NAME
AZURE_STORAGE_BLOB_PREFIX=attestations

# -----------------------------
# Security scanner endpoints (leave blank to use mock mode)
# -----------------------------
SONAR_URL=
CHECKMARX_URL=
MCP_API_KEY=

# -----------------------------
# Optional reviewer context (used for manual HITL decisions)
# -----------------------------
REVIEWER_DISPLAY_NAME=
REVIEWER_PRINCIPAL_ID=
REVIEWER_ROLE=

# -----------------------------
# Approval enforcement
# -----------------------------
# true: requires verified reviewer identity + role for manual decisions.
STRICT_ENTERPRISE_APPROVAL=